# ============================================================================
# .env Configuration for Image Upload Storage - HOSTING VERSION
# ============================================================================
# 
# COPY THIS to .env file di hosting dan sesuaikan:
# 1. APP_URL = ganti dengan domain Anda (tanpa trailing slash!)
# 2. DATABASE credentials = sesuaikan dengan hosting Anda
# 3. MAIL settings = optional, untuk pengiriman email
#
# ============================================================================

APP_NAME="Kelurahan Petamburan"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_KEY_HERE_GENERATED_BY_artisan_key_generate
APP_URL=https://kelurahan-petamburan.id

# ⚠️ IMPORTANT UNTUK UPLOAD GAMBAR:
# APP_URL harus:
# ✅ https://kelurahan-petamburan.id (BENAR)
# ✅ http://kelurahan-petamburan.id (BENAR jika tidak pakai SSL)
# ❌ Jangan pakai trailing slash: https://kelurahan-petamburan.id/
# ❌ Jangan pakai path: https://kelurahan-petamburan.id/admin
# ❌ Jangan pakai localhost

LOG_CHANNEL=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=kelurahan_db
DB_USERNAME=root
DB_PASSWORD=password

# Broadcast
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local

# 🎯 STORAGE CONFIGURATION (untuk gambar upload)
# FILESYSTEM_DISK bisa:
# ✅ "local" (default, gunakan ini)
# ✅ "public" (alternative, tapi sama hasilnya)
# Keduanya menyimpan ke: storage/app/public/
#
# URL akan otomatis: https://domain.id/storage/...

QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@kelurahan-petamburan.id
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

SANCTUM_SKIPPED_MIDDLEWARE=throttle:60,12

# ============================================================================
# SETUP LANGKAH-LANGKAH:
# 
# 1. Copy content ini ke .env di hosting
# 2. Ganti APP_KEY dengan hasil: php artisan key:generate
# 3. Sesuaikan database credentials
# 4. Jalankan: php artisan storage:initialize
# 5. Buat folder: mkdir -p storage/app/public/{sliders,news,galleries,...}
# 6. Create symlink: php artisan storage:link
# 7. Fix permission: chown -R www-data:www-data storage/
# 8. Clear cache: php artisan config:clear
# 9. Test upload gambar di Admin
#
# ============================================================================
